import os
import json
import re
import requests
from google import genai
import firebase_admin
from firebase_admin import credentials, firestore
import urllib.parse

service_account_info = json.loads(os.environ.get("FIREBASE_SERVICE_ACCOUNT"))
cred = credentials.Certificate(service_account_info)
firebase_admin.initialize_app(cred)
db = firestore.client()

client = genai.Client(api_key=os.environ.get("GEMINI_API_KEY"))
PEXELS_API_KEY = "5fkJHUN3D6bw2TV09HEiAHUHQJETwkSbPdIsCeCYXQGkYohfeU66VdW0"

def get_pexels_image(keyword):
    headers = {"Authorization": PEXELS_API_KEY}
    # اب یہ یہاں صرف وہی کی-ورڈ لے گا جو ہم اسے بھیجیں گے، کوئی ایکسٹرا ورڈ نہیں
    url = f"https://api.pexels.com/v1/search?query={urllib.parse.quote(keyword)}&per_page=1"
    try:
        response = requests.get(url, headers=headers).json()
        if 'photos' in response and len(response['photos']) > 0:
            return response['photos'][0]['src']['large']
    except:
        pass
    return "https://images.pexels.com/photos/3184418/pexels-photo-3184418.jpeg"

def process_posts():
    docs = db.collection('raw_jobs').where(filter=firestore.FieldFilter('status', '==', 'pending')).order_by('created_at', direction=firestore.Query.DESCENDING).limit(1).get()
    
    for doc in docs:
        data = doc.to_dict()
        for key, value in data.items():
            if hasattr(value, 'isoformat'):
                data[key] = value.isoformat()
        
        prompt = f"""
        Analyze the following raw data: {json.dumps(data)}.
        
        Task: 
        1. Create a professional, SEO-friendly Title. 
        2. Write a direct, agency-style content (250 words).
        3. Extract: 'contact_number', 'contact_email', 'apply_link'.
        4. Classify as: 'jobs', 'visa', or 'travel'.
        
        INSTRUCTIONS:
        - Output ONLY valid JSON: {{title, content, contact_number, contact_email, apply_link, category}}.
        - Title: [Category] in [Country] [Year] - [Role]. (Use year from raw data). NO 'Opportunities', NO 'Guide'.
        - Content: Write like a recruitment agency. Focus on benefits and requirements. NO filler words.
        - Forbidden Words: 'opportunities', 'verified', 'guide', 'professional', 'strategy', 'emerging', 'transformation'.
        """
        
        try:
            response = client.models.generate_content(model='gemini-3.1-flash-lite', contents=prompt)
            clean_text = response.text.replace('```json', '').replace('```', '').strip()
            content_json = json.loads(clean_text)
            
            # یہاں اب تصویر کا سرچ کی-ورڈ صرف کیٹیگری اور ٹائٹل پر مشتمل ہے
            image_query = f"{content_json.get('category')} {content_json.get('title')}"
            final_image_url = get_pexels_image(image_query)
            
            db.collection('published_posts').add({
                'title': content_json['title'],
                'content': content_json['content'],
                'image_url': final_image_url,
                'contact_number': content_json.get('contact_number'),
                'contact_email': content_json.get('contact_email'),
                'apply_link': content_json.get('apply_link'),
                'category': content_json.get('category', 'jobs'),
                'created_at': firestore.SERVER_TIMESTAMP
            })
            
            db.collection('raw_jobs').document(doc.id).update({'status': 'success'})
            break
            
        except Exception as e:
            print(f"Error: {e}")

if __name__ == "__main__":
    process_posts()
